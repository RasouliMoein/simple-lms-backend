# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1255, pipenv should generally check in Pipfile.lock.
#   For a package, do not check Pipfile.lock.
# Pipfile.lock

# poetry
#   Poetry uses pyproject.toml to manage dependencies and poetry.lock to lock them.
#   For a package, do not check poetry.lock.
# poetry.lock

# pdm
#   PDM stores project-wide configurations in .pdm.toml
.pdm.toml
.pdm-plugins/

# virtualenv
.venv/
venv/
ENV/
env/
# Environment files
.env
.flaskenv

